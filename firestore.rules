rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // - uid: string (required)
    // - email: string (required)
    // - role: string (required, enum: admin, lojinha_manager, cantina_manager, scout_manager, inventory_manager)
    //
    // Collection: products
    // - barcode: string (required)
    // - name: string (required)
    // - price: number (required)
    // - stock: number (required)
    //
    // Collection: stock_transactions
    // - productId: string (required)
    // - type: string (required, enum: entry, exit)
    // - quantity: number (required)
    // - userId: string (required)
    //
    // Collection: financial_records
    // - type: string (required, enum: income, expense)
    // - amount: number (required)
    // - isExtraordinary: boolean
    //
    // Collection: scout_members
    // - paxtuId: string (required)
    // - name: string (required)
    // - status: string (required)
    //
    // Collection: assets
    // - name: string (required)
    // - status: string (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "ai.auroratech@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRole(role) {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User Rules
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isOwner(uid);
    }

    // Lojinha Rules
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || hasRole('lojinha_manager');
    }
    match /stock_transactions/{transactionId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || hasRole('lojinha_manager');
    }

    // Cantina Rules
    match /financial_records/{recordId} {
      allow read: if isAdmin() || hasRole('cantina_manager');
      allow write: if isAdmin() || hasRole('cantina_manager');
    }

    // Scout Rules
    match /scout_members/{memberId} {
      allow read: if isAdmin() || hasRole('scout_manager');
      allow write: if isAdmin() || hasRole('scout_manager');
    }

    // Asset Rules
    match /assets/{assetId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || hasRole('inventory_manager');
    }
  }
}
