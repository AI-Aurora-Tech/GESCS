rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // - uid: string (required)
    // - email: string (required)
    // - role: string (required, enum: admin, lojinha_manager, cantina_manager, scout_manager, inventory_manager)
    //
    // Collection: products
    // - barcode: string (required)
    // - name: string (required)
    // - price: number (required)
    // - stock: number (required)
    //
    // Collection: stock_transactions
    // - productId: string (required)
    // - type: string (required, enum: entry, exit)
    // - quantity: number (required)
    // - userId: string (required)
    //
    // Collection: financial_records
    // - type: string (required, enum: income, expense)
    // - amount: number (required)
    // - isExtraordinary: boolean
    //
    // Collection: scout_members
    // - paxtuId: string (required)
    // - name: string (required)
    // - status: string (required)
    //
    // Collection: assets
    // - name: string (required)
    // - status: string (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "ai.auroratech@gmail.com" ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function hasRole(role) {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role || isAdmin());
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'role']) &&
             data.uid is string &&
             data.email is string && data.email.size() > 0 &&
             data.displayName is string &&
             data.role in ['admin', 'lojinha_manager', 'cantina_manager', 'scout_manager', 'inventory_manager'];
    }

    // User Rules
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isOwner(uid) || isAdmin()) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (isAdmin() || (isOwner(uid) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role));
      allow delete: if isAdmin();
    }

    // Lojinha Rules
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('lojinha_manager');
    }
    match /stock_transactions/{transactionId} {
      allow read: if isAuthenticated();
      allow create: if hasRole('lojinha_manager');
    }
    match /lojinha_demands/{demandId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if hasRole('lojinha_manager');
    }

    // Cantina Rules
    match /financial_records/{recordId} {
      allow read: if hasRole('cantina_manager');
      allow write: if hasRole('cantina_manager');
    }
    match /cantina_materials/{materialId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('cantina_manager');
    }

    // Scout Rules
    match /scout_members/{memberId} {
      allow read: if hasRole('scout_manager');
      allow write: if hasRole('scout_manager');
    }

    // Asset Rules
    match /assets/{assetId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('inventory_manager');
    }
    match /inventory_demands/{demandId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if hasRole('inventory_manager');
    }
  }
}
